# Required for Vite build (local dev + Vercel). Copy to .env and fill in values.
# On Vercel: Project Settings → Environment Variables (must be set before deploy).

# Clerk publishable key (pk_test_... or pk_live_...) — either name works:
VITE_CLERK_PUBLISHABLE_KEY=
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=  # fallback if already set for Next.js on Vercel

# Backend API URL (required in production; defaults to http://localhost:8080 locally)
VITE_API_BASE_URL=http://localhost:8080

# Optional: Clerk Frontend API proxy URL (e.g. https://your-api.example.com/api/__clerk)
# VITE_CLERK_PROXY_URL=
